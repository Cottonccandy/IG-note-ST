{
    "name": "IG Notes Universal",
    "commands": [
        {
            "name": "show_ig_notes",
            "command": "/script `const notesUI = document.createElement('div'); notesUI.id = 'ig-notes-fixed'; notesUI.innerHTML = '<div style=\"position: sticky; top: 0; z-index: 999; background: white; padding: 10px; display: flex; justify-content: center; gap: 20px; border-bottom: 1px solid #ddd; width: 100%;\"><div style=\"text-align: center; width: 80px;\"><div style=\"background: white; border-radius: 12px; padding: 5px; font-size: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); border: 1px solid #eee; min-height: 30px; display: flex; align-items: center; justify-content: center;\">{{getvar::char_note}}</div><div style=\"width: 50px; height: 50px; border-radius: 50%; border: 2px solid #e1306c; margin: 5px auto 0; overflow: hidden;\"><img src=\"{{char_avatar}}\" style=\"width: 100%; height: 100%; object-fit: cover;\"></div><div style=\"font-size: 10px; font-weight: bold;\">{{char}}</div></div><div style=\"text-align: center; width: 80px;\"><input type=\"text\" value=\"{{getvar::user_note}}\" onchange=\"SillyTavern.postCommand(\\'/setvar name=user_note value=\\' + this.value)\" style=\"width: 100%; border-radius: 12px; padding: 5px; font-size: 10px; border: 1px solid #ddd; text-align: center;\"><div style=\"width: 50px; height: 50px; border-radius: 50%; border: 2px solid #dbdbdb; margin: 5px auto 0; overflow: hidden;\"><img src=\"{{user_avatar}}\" style=\"width: 100%; height: 100%; object-fit: cover;\"></div><div style=\"font-size: 10px;\">คุณ</div></div></div>'; document.querySelector('.chat-container').prepend(notesUI);`"
        }
    ],
    "automations": [
        {
            "event": "chat_ready",
            "command": "/show_ig_notes"
        }
    ]
}

